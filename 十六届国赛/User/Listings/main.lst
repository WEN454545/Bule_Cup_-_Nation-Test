1317          void Volumn_Calc(unsigned int Water_Lenth,unsigned int R_Set,unsigned int *L_W_H_Set,unsigned int S_Type,u
             -nsigned int *Volumn,unsigned char *Remain_Volumn,unsigned int *Water_d)
1318          {
1319   1        unsigned int Sum_Volumn = 0;   
1320   1        *Water_d = 0;
1321   1           
1322   1        switch(S_Type)
1323   1        {
1324   2          case 0:     //球
1325   2                  *Water_d = (2* R_Set - Water_Lenth);      //液面高度
1326   2                  if (*Water_d > 60000)
1327   2                  {
1328   3                      *Water_d = 0;
1329   3                  }
1330   2                  
1331   2                  Sum_Volumn = (unsigned int)(4 / 3 * 3.14f * R_Set/10 * R_Set/10 * R_Set/10 / 100) ;
1332   2            *Volumn = (unsigned int)(3.14f * *Water_d/10 * *Water_d/10 * (R_Set/10- (*Water_d / 30)) / 100) ;      
             -           //Π * d^2 * (R - d/3)
1333   2                  *Remain_Volumn = (unsigned char)( Sum_Volumn / 100.0f * *Volumn);         //剩余体积比
1334   2            break;
C51 COMPILER V9.56.0.0   MAIN                                                              03/23/2026 17:39:38 PAGE 23  

1335   2              case 1:     //圆柱体
1336   2                  *Water_d = (L_W_H_Set[2] - Water_Lenth);      //液面高度
1337   2                  Sum_Volumn = (unsigned int)(3.14f * R_Set/10 * R_Set/10 * (L_W_H_Set[2] /10) / 100);
1338   2                  if(*Water_d < 60000 || *Water_d == 0)
1339   2                  {
1340   3                      *Volumn = (unsigned int)(3.14f * R_Set/10 * R_Set/10 * *Water_d/10 / 100);
1341   3                      *Remain_Volumn = (unsigned char)( Sum_Volumn / 100.0f * *Volumn );         //剩余体积比
1342   3                  }
1343   2                  else{
1344   3                      *Water_d = 0;
1345   3                      *Volumn = 0;
1346   3                      *Remain_Volumn = 100;
1347   3                  }
1348   2                  
1349   2                  break;
1350   2              case 2:     //立方体
1351   2                  *Water_d = (L_W_H_Set[2] - Water_Lenth);      //液面高度
1352   2                  Sum_Volumn = L_W_H_Set[0]/10 * L_W_H_Set[1]/10 * L_W_H_Set[2] /10 / 100;
1353   2                  if(*Water_d < 60000 || *Water_d == 0)
1354   2                  {
