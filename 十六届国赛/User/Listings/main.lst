1356   3                      *Remain_Volumn = (unsigned char)( ((Sum_Volumn -*Volumn) * 100.0f) / (Sum_Volumn * 100.0f)
             - * 100);         //剩余体积比
1357   3                  }
1358   2                  else 
1359   2                  {
1360   3                      *Water_d = 0;
