1281          //提取标识      pos缓存值，方便递归使用
1282          unsigned char Uart_Get_IdAndValue(unsigned char pos,unsigned char *Uart_Id,unsigned char *id_value)
1283          {
1284   1          i = 0;
1285   1          while(pos < Uart_Rx_Index && Uart_Recv[pos] != '(')
1286   1              pos++;
1287   1      
1288   1          if(pos >= Uart_Rx_Index) return 0xff;       //未找到
1289   1      
1290   1          pos++;      //跳过'('
1291   1      
1292   1          //提取标识ID
1293   1          while(pos < Uart_Rx_Index && Uart_Recv[pos] != ',' && Uart_Recv[pos] != ':')
1294   1          {
1295   2              Uart_Id[i++] = Uart_Recv[pos];
1296   2              pos++;
1297   2              
1298   2          }
1299   1              Uart_Id[i] = '\0';  
1300   1              pos++;      //跳过','
1301   1      
1302   1      
1303   1              //提取数值
1304   1              i = 0;      //重新计数，记录数值
1305   1              while(pos < Uart_Rx_Index && Uart_Recv[pos] != ')')
1306   1              {
1307   2                  id_value[i++] = Uart_Recv[pos];
1308   2                  pos++;
1309   2              }
1310   1              id_value[i] = '\0';
1311   1              //pos++;      //跳过')'
1312   1      
1313   1              return pos;         //返回下一个位置——')'的位置
1314   1      }
