  11          sbit RST = P1^3;
  12          sbit SCK = P1^7;
  13          sbit SDA = P2^3;
  14          
  15          //
  16          void Write_Ds1302(unsigned  char temp) 
  17          {
  18   1        unsigned char i;
  19   1        for (i=0;i<8;i++)       
  20   1        { 
  21   2          SCK = 0;
  22   2          SDA = temp&0x01;
  23   2          temp>>=1; 
  24   2          SCK=1;
  25   2        }
  26   1      }   
  27          
  28          //
  29          void Write_Ds1302_Byte( unsigned char address,unsigned char dat )     
  30          {
  31   1        RST=0;  _nop_();
  32   1        SCK=0;  _nop_();
  33   1        RST=1;  _nop_();  
  34   1        Write_Ds1302(address);  
  35   1        Write_Ds1302(dat);    
  36   1        RST=0; 
  37   1      }
  38          
  39          //
  40          unsigned char Read_Ds1302_Byte ( unsigned char address )
  41          {
  42   1        unsigned char i,temp=0x00;
  43   1        RST=0;  _nop_();
  44   1        SCK=0;  _nop_();
  45   1        RST=1;  _nop_();
  46   1        Write_Ds1302(address);
  47   1        for (i=0;i<8;i++)   
  48   1        {   
  49   2          SCK=0;
  50   2          temp>>=1; 
  51   2          if(SDA)
  52   2          temp|=0x80; 
  53   2          SCK=1;
