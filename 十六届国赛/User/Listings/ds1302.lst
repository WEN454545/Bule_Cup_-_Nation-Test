  62          
  63          void Set_Timer(unsigned char *Timer)
  64          {
  65   1        unsigned char i;
  66   1        Write_Ds1302_Byte(0x8e,0x00);   //е…іеҶҷдҝқжҠӨ
  67   1        Write_Ds1302_Byte(0x80,0x80);   //еҒңжӯўи®Ўж—¶
  68   1        for(i=0;i<3;i++)
  69   1        {
  70   2          Timer[i] = ((Timer[i] / 10 % 10) << 4) | (Timer[i] % 10);     //еҚҒиҝӣеҲ¶иҪ¬bcdз Ғ
  71   2          Write_Ds1302_Byte(0x84 - 2*i,Timer[i]);
  72   2        }
  73   1        Write_Ds1302_Byte(0x8e,0x80);   //жү“ејҖеҶҷдҝқжҠӨ
  74   1      
  75   1      }
  76          
  77          void Read_Timer(unsigned char *Timer)
  78          {
  79   1        unsigned char i; 
  80   1        unsigned char temp;
  81   1        EA = 0;
  82   1        for(i=0;i<3;i++)
  83   1        {
  84   2          temp = Read_Ds1302_Byte(0x85 - 2*i);
  85   2          Timer[i] = (temp / 16 * 10) + (temp % 16);
  86   2        }
  87   1        EA = 1;
  88   1      
  89   1      }
